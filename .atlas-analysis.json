  "keyFeatures": [
    "Native Windows UI automation through accessibility tree",
    "15 MCP tools for comprehensive desktop control",
    "Browser DOM extraction with use_dom mode",
    "Multi-display support with coordinate mapping",
    "Local and remote execution modes",
    "Lightweight with minimal dependencies",
    "Real-time interaction (0.2-0.9s latency)",
    "Works with any LLM without vision requirements"
  ],
  "publicApiSurface": [
    "Snapshot - Capture desktop state and UI elements",
    "Click - Mouse click operations",
    "Type - Text input and keyboard typing",
    "Scroll - Vertical and horizontal scrolling",
    "Move - Mouse movement and drag operations",
    "Shortcut - Keyboard shortcut execution",
    "App - Application launch and window management",
    "PowerShell - Shell command execution",
    "FileSystem - File and directory operations",
    "Scrape - Web content extraction",
    "MultiSelect - Multiple item selection",
    "MultiEdit - Batch text input",
    "Clipboard - Clipboard operations",
    "Process - Process management",
    "Notification - Windows toast notifications",
    "Registry - Windows Registry operations",
    "Wait - Execution delays"
  ]
